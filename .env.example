# ---- Core ----
NODE_ENV=development

# ---- PostgreSQL 16 ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/marketplace

# ---- Redis 7 (cache + pub/sub + BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-different-long-random-string
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000       # 30 days (seconds)

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret-token

# ---- API ----
API_PORT=3000
CORS_ORIGINS=https://app.example.com,https://t.me


# ---- Telegram Bot (apps/bot) ----
TELEGRAM_BOT_USERNAME=my_bot           # without @
TELEGRAM_MINIAPP_SHORTNAME=shop        # BotFather Mini App short name
TELEGRAM_MINIAPP_URL=https://app.example.com   # web_app button target
API_BASE_URL=http://localhost:3000/v1
BOT_SERVICE_TOKEN=replace-with-server-to-server-token
DEFAULT_LOCALE=en


# ---- Payment webhook secrets (per provider, suffix uppercased) ----
PAYMENT_WEBHOOK_SECRET_STRIPE=whsec_replace_me
PAYMENT_WEBHOOK_SECRET_PAYSTACK=replace_me
